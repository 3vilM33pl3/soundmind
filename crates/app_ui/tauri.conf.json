{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soundmind",
  "version": "0.1.0",
  "identifier": "io.soundmind.desktop",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Soundmind",
        "width": 1320,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.svg"]
  }
}
